from ultralytics import YOLO


def main() -> None:
    model_path = r"C:\Users\danie\Downloads\best.pt"
    image_path = r"C:\Users\danie\Downloads\IMG_6186.JPG"

    print(f"Lade YOLO-Modell von {model_path}")
    model = YOLO(model_path)
    print(f"Modell geladen. Klassen: {model.names}")

    print(f"Analysiere Bild: {image_path}")
    results = model(image_path, imgsz=640, conf=0.1, verbose=False)

    if not results:
        print("Keine Ergebnisse erhalten.")
        return

    result = results[0]
    boxes = getattr(result, "boxes", None)
    if boxes is None or len(boxes) == 0:
        print("Keine erkannten Objekte.")
        return

    xyxy = boxes.xyxy.cpu().numpy()
    confs = boxes.conf.cpu().numpy()
    classes = boxes.cls.cpu().numpy().astype(int)

    print(f"Erkannte Objekte: {len(classes)}")
    for idx, (bbox, cls_id, conf) in enumerate(zip(xyxy, classes, confs), start=1):
        class_name = model.names.get(int(cls_id), f"class_{cls_id}")
        x1, y1, x2, y2 = bbox.tolist()
        print(f"{idx}: {class_name} (id={cls_id}, conf={conf:.3f}) bbox=[{x1:.1f}, {y1:.1f}, {x2:.1f}, {y2:.1f}]")


if __name__ == "__main__":
    main()
